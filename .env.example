# PostgreSQL / Redis
POSTGRES_USER=token_factory
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=token_factory
DATABASE_URL=postgresql://token_factory:change-me-in-production@postgres:5432/token_factory?schema=public
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=change-this-redis-password

# Public URLs
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
ADMIN_BASE_URL=http://localhost:3001
GATEWAY_PUBLIC_URL=http://localhost:8000
INTERNAL_API_URL=http://gateway:8000
DOMAIN=yourdomain.com
API_DOMAIN=api.yourdomain.com
LETSENCRYPT_EMAIL=admin@yourdomain.com

# Authentication (replace every value in production)
ADMIN_PASSWORD=change-this-admin-password
INTERNAL_API_TOKEN=change-this-internal-token
JWT_SECRET=change-this-at-least-32-characters
API_KEY_PEPPER=change-this-api-key-pepper

# Email
RESEND_API_KEY=
EMAIL_FROM=Token Factory <noreply@example.com>

# S3-compatible storage (local disk is used when S3_ENDPOINT is empty)
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=token-factory
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
UPLOAD_DIR=/data/uploads
EXPORT_DIR=/data/exports

# Default OpenAI-compatible provider
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small

# Agent provider (falls back to the default provider when empty)
AGENT_CHAT_API_KEY=
AGENT_CHAT_BASE_URL=
AGENT_CHAT_MODEL=gpt-4o-mini

# RAG provider (falls back to the default provider when empty)
RAG_CHAT_API_KEY=
RAG_CHAT_BASE_URL=
RAG_CHAT_MODEL=gpt-4o-mini

# Worker feature flags
ENABLE_WORKER_CRON=true
ENABLE_LOG_CLEANUP=true
ENABLE_AUTO_EVAL=false
ENABLE_LLM_EVAL=false
WORKER_CONCURRENCY=1
SEED_DEMO_USER=false

# Runtime tuning
PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
DEFAULT_USER_CREDIT=5
RATE_LIMIT_PER_MINUTE=60
CIRCUIT_BREAKER_FAILURES=3
CIRCUIT_BREAKER_RESET_SECONDS=60
RESERVATION_TTL_SECONDS=300
LOG_RETENTION_DAYS=90
